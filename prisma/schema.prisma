generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model usuario {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(120)
  email     String   @unique(map: "Usuario_email_key") @db.VarChar(120)
  createdAt DateTime @default(now())
  updatedAt DateTime
}
